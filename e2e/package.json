{
  "name": "@open-design/e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run -c vitest.config.ts",
    "test:ui:clean": "node scripts/reset-artifacts.mjs",
    "test:ui": "pnpm run test:ui:clean && playwright test -c playwright.config.ts",
    "test:ui:headed": "pnpm run test:ui:clean && playwright test -c playwright.config.ts --headed",
    "test:e2e:live": "node --test scripts/runtime-adapter.e2e.live.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.17.10",
    "jsdom": "^29.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "~24"
  }
}
